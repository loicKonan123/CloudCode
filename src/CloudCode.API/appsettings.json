{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=CloudCode.db"
  },
  "Terminal": {
    "WorkingDirectory": "",
    "PythonPath": "python",
    "NodePath": "node",
    "NpmPath": "npm"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "CloudCode",
    "Audience": "CloudCodeUsers",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://localhost:3000"
    ]
  },
  "CodeExecution": {
    "TimeoutSeconds": 30,
    "MaxMemoryMB": 256,
    "MaxOutputLength": 50000
  },
  "AppProxy": {
    "Enabled": true,
    "PortRange": "3000-3100",
    "Timeout": 30000
  },
  "AI": {
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-4"
    },
    "Anthropic": {
      "ApiKey": "",
      "Model": "claude-3-sonnet"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Firebase": {
    "ServiceAccountPath": "../../firebase_key.json"
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "onboarding@resend.dev"
  },
  "App": {
    "FrontendUrl": "http://localhost:3000"
  },
  "Stripe": {
    "SecretKey": "",
    "PriceId": "",
    "WebhookSecret": ""
  },
  "AllowedHosts": "*"
}
